<!--pages/woodfish/woodfish.wxml-->
<view class="container" bindtap="onTapWoodfish">
  <!-- 功德计数器 -->
  <view class="merit-container">
    <view class="merit-label">功德</view>
    <view class="merit-value {{meritAnimating ? 'bounce' : ''}}">{{merit}}</view>
  </view>

  <!-- 木鱼区域 -->
  <view class="woodfish-area">
    <!-- 木鱼主体 -->
    <view class="muyu-body {{isKnocking ? 'knocking' : ''}}">
      <view class="muyu-outer">
        <view class="muyu-inner">
          <view class="muyu-mouth"></view>
        </view>
        <view class="muyu-shine"></view>
      </view>
    </view>

    <!-- 木槌 -->
    <view class="mallet {{isKnocking ? 'swinging' : ''}}">
      <view class="mallet-head"></view>
      <view class="mallet-handle"></view>
    </view>

    <!-- 波纹 -->
    <view wx:if="{{showRipple}}" class="ripple-container">
      <view class="ripple ripple-1"></view>
      <view class="ripple ripple-2"></view>
    </view>

    <!-- 飘字 -->
    <view wx:for="{{meritPopups}}" wx:key="id" class="merit-popup">
      功德+{{item.count}}
    </view>
  </view>

  <!-- 右侧按钮 -->
  <view class="side-btns">
    <view class="side-btn settings-btn" catchtap="goToSettings">
      <text class="side-btn-icon">☸</text>
    </view>
  </view>

  <!-- 底部分享按钮 -->
  <view class="bottom-btns">
    <button class="share-btn" open-type="share">
      <text class="share-icon">🙏</text>
      <text class="share-text">邀请好友</text>
    </button>
  </view>
</view>
