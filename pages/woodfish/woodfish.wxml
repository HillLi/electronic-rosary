<!--pages/woodfish/woodfish.wxml-->
<view class="container" bindtap="onTapWoodfish">
  <!-- 檀香烟雾粒子 -->
  <view class="incense-particles">
    <view class="particle particle-1"></view>
    <view class="particle particle-2"></view>
    <view class="particle particle-3"></view>
    <view class="particle particle-4"></view>
    <view class="particle particle-5"></view>
  </view>

  <!-- 功德计数器 -->
  <view class="merit-container">
    <view class="merit-label">功德</view>
    <view class="merit-value {{meritAnimating ? 'bounce' : ''}}">{{merit}}</view>
  </view>

  <!-- 木鱼区域 -->
  <view class="woodfish-area">
    <!-- 木鱼图片 -->
    <view class="woodfish-image-wrapper {{isKnocking ? 'knocking' : ''}}">
      <image
        class="woodfish-image"
        src="/assets/images/woodfish.png"
        mode="aspectFit"
      />
    </view>

    <!-- 木槌 -->
    <view class="mallet {{isKnocking ? 'swinging' : ''}}">
      <image class="mallet-image" src="/assets/images/mallet.png" mode="aspectFit" />
    </view>

    <!-- 波纹 -->
    <view wx:if="{{showRipple}}" class="ripple-container">
      <view class="ripple ripple-1"></view>
      <view class="ripple ripple-2"></view>
      <view class="ripple ripple-3"></view>
    </view>

    <!-- 飘字 -->
    <view wx:for="{{meritPopups}}" wx:key="id" class="merit-popup">
      功德+{{item.count}}
    </view>
  </view>

  <!-- 右侧按钮 -->
  <view class="side-btns">
    <view class="side-btn auto-btn {{autoKnock ? 'active' : ''}}" catchtap="toggleAutoKnock">
      <text class="side-btn-icon">{{autoKnock ? '⏸' : '▶'}}</text>
    </view>
    <view class="side-btn settings-btn" catchtap="goToSettings">
      <text class="side-btn-icon">☸</text>
    </view>
  </view>

  <!-- 底部分享按钮 -->
  <view class="bottom-btns">
    <button class="share-btn" open-type="share">
      <text class="share-icon">🙏</text>
      <text class="share-text">邀请好友</text>
    </button>
  </view>
</view>
