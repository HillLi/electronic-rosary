/* pages/woodfish/woodfish.wxss - 禅意檀香主题 */

/* ========================================
   主容器 - 禅意氛围背景
   ======================================== */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  height: 100vh;
  padding: 40rpx 0;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
  background: linear-gradient(180deg, #F8F4EF 0%, #F0E6D8 30%, #E8D8C5 60%, #DDD0BC 100%);
}

/* 背景图片层 */
.background-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 檀香烟雾氛围层 */
.container::before {
  content: '';
  position: absolute;
  top: -20%;
  left: -10%;
  right: -10%;
  bottom: -20%;
  background:
    radial-gradient(ellipse 80% 50% at 20% 30%, rgba(139, 90, 43, 0.03) 0%, transparent 50%),
    radial-gradient(ellipse 60% 40% at 80% 70%, rgba(139, 90, 43, 0.02) 0%, transparent 50%),
    radial-gradient(ellipse 100% 60% at 50% 100%, rgba(184, 134, 11, 0.02) 0%, transparent 40%);
  pointer-events: none;
  z-index: 0;
}

/* ========================================
   檀香烟雾粒子 - 禅意氛围
   ======================================== */
.incense-particles {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}

.particle {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  background: radial-gradient(circle,
    rgba(184, 134, 11, 0.15) 0%,
    rgba(184, 134, 11, 0.05) 50%,
    transparent 100%
  );
  border-radius: 50%;
  animation: floatUp 8s ease-in-out infinite;
}

.particle-1 {
  left: 15%;
  bottom: 20%;
  animation-delay: 0s;
  animation-duration: 10s;
}

.particle-2 {
  left: 30%;
  bottom: 15%;
  animation-delay: 1.5s;
  animation-duration: 12s;
  width: 4rpx;
  height: 4rpx;
}

.particle-3 {
  left: 50%;
  bottom: 25%;
  animation-delay: 3s;
  animation-duration: 9s;
}

.particle-4 {
  left: 70%;
  bottom: 18%;
  animation-delay: 4.5s;
  animation-duration: 11s;
  width: 5rpx;
  height: 5rpx;
}

.particle-5 {
  left: 85%;
  bottom: 22%;
  animation-delay: 6s;
  animation-duration: 13s;
  width: 4rpx;
  height: 4rpx;
}

@keyframes floatUp {
  0% {
    transform: translateY(0) translateX(0) scale(0.5);
    opacity: 0;
  }
  10% {
    opacity: 0.6;
  }
  50% {
    transform: translateY(-300rpx) translateX(20rpx) scale(1);
    opacity: 0.4;
  }
  90% {
    opacity: 0.1;
  }
  100% {
    transform: translateY(-600rpx) translateX(-10rpx) scale(0.3);
    opacity: 0;
  }
}

/* ========================================
   功德计数器 - 醒目样式
   ======================================== */
.merit-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
  position: relative;
  z-index: 10;
}

.merit-label {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 20rpx;
  color: rgb(255, 255, 255);
  margin-bottom: 12rpx;
  text-indent: 20rpx;
  text-shadow: 0 2rpx 8rpx rgba(60, 35, 20, 0.5);
}

.merit-value {
  font-size: 60rpx;
  font-weight: 700;
  color: #FFD700;
  text-shadow:
    0 0 10rpx rgba(255, 215, 0, 0.8),
    0 0 30rpx rgba(255, 180, 0, 0.5),
    0 0 50rpx rgba(255, 140, 0, 0.3),
    0 4rpx 8rpx rgba(60, 35, 20, 0.4);
  line-height: 1.2;
  position: relative;
  -webkit-text-stroke: 1rpx rgba(180, 120, 0, 0.3);
}

/* 功德数字下方装饰线 */
.merit-value::after {
  content: '';
  position: absolute;
  bottom: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 3rpx;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 215, 0, 0.8) 20%,
    transparent 100%
  );
  box-shadow: 0 0 10rpx rgba(255, 200, 100, 0.5);
}

.merit-value.bounce {
  animation: meritPulse 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes meritPulse {
  0% { transform: scale(1); }
  40% { transform: scale(1.08); }
  100% { transform: scale(1); }
}

/* ========================================
   木鱼区域
   ======================================== */
.woodfish-area {
  position: absolute;
  top: 75%;
  left: 80rpx;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  z-index: 5;
}

/* 木鱼图片容器 */
.woodfish-image-wrapper {
  width: 550rpx;
  height: 500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.woodfish-image-wrapper.knocking {
  animation: woodfishShake 3.3s ease-in-out;
}

@keyframes woodfishShake {
  0%, 100% { transform: scale(1) rotate(0deg); }
  25% { transform: scale(0.97) rotate(-1deg); }
  50% { transform: scale(1.02) rotate(0deg); }
  75% { transform: scale(0.99) rotate(1deg); }
}

.woodfish-image {
  width: 100%;
  height: 100%;
}

/* ========================================
   木槌 - 敲击动画（图片版）
   ======================================== */
.mallet {
  position: absolute;
  right: -150rpx;
  top: -20%;
  transform: rotate(20deg);
  transform-origin: bottom center;
  z-index: 10;
}

.mallet-image {
  width: 350rpx;
  height: 350rpx;
}

.mallet.swinging {
  animation: malletSwing 0.25s ease-out;
}

@keyframes malletSwing {
  0% { transform: rotate(20deg); }
  50% { transform: rotate(-30deg); }
  100% { transform: rotate(20deg); }
}

/* ========================================
   波纹效果 - 增强版（主要视觉反馈）
   ======================================== */
.ripple-container {
  position: absolute;
  top: 50%;
  left: 248rpx;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.ripple {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(184, 134, 11, 0.5);
  box-shadow: 0 0 20rpx rgba(184, 134, 11, 0.2);
  animation: rippleExpand 0.6s ease-out forwards;
}

.ripple-2 {
  animation-delay: 0.08s;
}

.ripple-3 {
  animation-delay: 0.16s;
}

@keyframes rippleExpand {
  0% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.7;
  }
  100% {
    transform: translate(-50%, -50%) scale(2);
    opacity: 0;
  }
}

/* ========================================
   功德飘字 - 醒目效果
   ======================================== */
.merit-popup {
  position: absolute;
  left: 180rpx;
  top: 50%;
  margin-top: -200rpx;
  transform: translateX(-50%);
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: #FFD700;
  text-shadow:
    0 0 8rpx rgba(255, 215, 0, 0.9),
    0 0 20rpx rgba(255, 180, 0, 0.6),
    0 0 40rpx rgba(255, 140, 0, 0.4),
    0 2rpx 4rpx rgba(60, 35, 20, 0.5);
  -webkit-text-stroke: 1rpx rgba(180, 100, 0, 0.3);
  white-space: nowrap;
  pointer-events: none;
  z-index: 9999;
  animation: meritRise 1.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

@keyframes meritRise {
  0% {
    opacity: 0;
    transform: translateY(-30rpx) scale(0.7);
  }
  15% {
    opacity: 1;
    transform: translateY(-100rpx) scale(1.05);
  }
  30% {
    transform: translateY(-140) scale(1);
  }
  70% {
    opacity: 0.9;
    transform: translateY(-240rpx) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(-300rpx) scale(0.9);
  }
}

/* ========================================
   右侧按钮区域 - 右上角竖向排列
   ======================================== */
.side-btns {
  position: fixed;
  right: 32rpx;
  top: 30%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  z-index: 100;
}

.side-btn-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.side-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.95) 0%,
    rgba(250, 245, 240, 0.9) 100%
  );
  border: 1rpx solid rgba(139, 90, 43, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 4rpx 16rpx rgba(60, 35, 20, 0.08),
    0 2rpx 8rpx rgba(60, 35, 20, 0.04);
}

.side-btn-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFF5E6;
  letter-spacing: 2rpx;
  text-shadow: 0 1rpx 4rpx rgba(60, 35, 20, 0.5);
}

.side-btn-icon {
  font-size: 40rpx;
  opacity: 0.85;
}

/* 自动敲击按钮激活状态 */
.side-btn.auto-btn.active {
  background: linear-gradient(135deg,
    rgba(184, 134, 11, 0.2) 0%,
    rgba(184, 134, 11, 0.1) 100%
  );
  border-color: rgba(184, 134, 11, 0.4);
}

/* 重置按钮特殊样式 */
.side-btn.reset-btn {
  background: linear-gradient(135deg,
    rgba(180, 80, 80, 0.15) 0%,
    rgba(255, 255, 255, 0.95) 100%
  );
}

/* ========================================
   底部分享按钮 - 深棕对比色
   ======================================== */
.bottom-btns {
  padding-bottom: 24rpx;
  z-index: 10;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 56rpx;
  background: linear-gradient(135deg,
    rgba(90, 55, 30, 0.85) 0%,
    rgba(70, 45, 25, 0.9) 100%
  );
  border-radius: 48rpx;
  border: 2rpx solid rgba(140, 90, 50, 0.5);
  box-shadow:
    0 4rpx 20rpx rgba(60, 35, 20, 0.3),
    0 2rpx 8rpx rgba(40, 25, 15, 0.2);
}

.share-btn::after {
  border: none;
}

.share-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.share-text {
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 6rpx;
  color: #FFF5E6;
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.3);
}
