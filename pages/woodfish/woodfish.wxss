/* pages/woodfish/woodfish.wxss */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  height: 100vh;
  padding: 40rpx 0;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
  background: #F5E6D3;
}

.merit-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  z-index: 10;
}

.merit-label {
  font-size: 28rpx;
  letter-spacing: 16rpx;
  color: #8B7355;
  margin-bottom: 8rpx;
}

.merit-value {
  font-size: 96rpx;
  font-weight: 300;
  color: #3D2314;
  line-height: 1.2;
}

.merit-value.bounce {
  animation: meritPulse 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes meritPulse {
  0% { transform: scale(1); }
  40% { transform: scale(1.08); }
  100% { transform: scale(1); }
}

.woodfish-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 5;
}

.muyu-body {
  position: relative;
  width: 320rpx;
  height: 320rpx;
}

.muyu-body.knocking {
  animation: muyuShake 0.15s ease-in-out;
}

@keyframes muyuShake {
  0%, 100% { transform: scale(1) rotate(0deg); }
  25% { transform: scale(0.97) rotate(-1deg); }
  50% { transform: scale(1.02) rotate(0deg); }
  75% { transform: scale(0.99) rotate(1deg); }
}

.muyu-outer {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, #C19A6B 0%, #8B6914 25%, #6B4423 50%, #4A3728 75%, #3D2914 100%);
  box-shadow: inset 0 -8rpx 20rpx rgba(0,0,0,0.4), inset 0 8rpx 24rpx rgba(255,255,255,0.1), 0 8rpx 32rpx rgba(0,0,0,0.35);
  position: relative;
  overflow: hidden;
}

.muyu-inner {
  position: absolute;
  top: 15%;
  left: 15%;
  width: 70%;
  height: 70%;
  border-radius: 50%;
  background: radial-gradient(circle at 40% 35%, #5D4434 0%, #4A3525 40%, #3D2A1A 70%, #2D1F14 100%);
  box-shadow: inset 0 4rpx 16rpx rgba(0,0,0,0.5);
}

.muyu-mouth {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 40%;
  height: 15%;
  background: linear-gradient(180deg, #1A1208 0%, #2D1F14 50%, #1A1208 100%);
  border-radius: 50%;
  box-shadow: inset 0 2rpx 6rpx rgba(0,0,0,0.6);
}

.muyu-shine {
  position: absolute;
  top: 8%;
  left: 15%;
  width: 40%;
  height: 25%;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.25) 0%, rgba(255,255,255,0.08) 50%, transparent 100%);
  transform: rotate(-25deg);
}

.mallet {
  position: absolute;
  right: -80rpx;
  top: 50%;
  transform: translateY(-50%) rotate(-30deg);
  z-index: 10;
}

.mallet.swinging {
  animation: malletSwing 0.15s ease-out;
}

@keyframes malletSwing {
  0% { transform: translateY(-50%) rotate(-30deg); }
  50% { transform: translateY(-50%) rotate(5deg); }
  100% { transform: translateY(-50%) rotate(-30deg); }
}

.mallet-head {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, #D4A574 0%, #8B6914 40%, #6B4423 70%, #4A3728 100%);
  box-shadow: inset 0 -3rpx 8rpx rgba(0,0,0,0.35), inset 0 3rpx 10rpx rgba(255,255,255,0.15), 0 4rpx 12rpx rgba(0,0,0,0.25);
}

.mallet-handle {
  width: 16rpx;
  height: 120rpx;
  margin-left: 22rpx;
  margin-top: -4rpx;
  background: linear-gradient(90deg, #6B4423 0%, #8B6914 30%, #A0784C 50%, #8B6914 70%, #6B4423 100%);
  border-radius: 8rpx;
  box-shadow: 2rpx 2rpx 8rpx rgba(0,0,0,0.15);
}

.ripple-container {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.ripple {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(184, 134, 11, 0.5);
  animation: rippleExpand 0.6s ease-out forwards;
}

.ripple-2 {
  animation-delay: 0.1s;
}

@keyframes rippleExpand {
  0% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
  100% { transform: translate(-50%, -50%) scale(1.8); opacity: 0; }
}

.merit-popup {
  position: absolute;
  left: 50%;
  top: 50%;
  margin-top: -80rpx;
  margin-left: -55rpx;
  font-size: 32rpx;
  color: #B8860B;
  text-shadow: 0 0 12rpx rgba(218, 165, 32, 0.5);
  white-space: nowrap;
  pointer-events: none;
  z-index: 9999;
  animation: meritRise 1.2s forwards;
}

@keyframes meritRise {
  0% { opacity: 0; transform: translateY(40rpx) scale(0.7); }
  15% { opacity: 1; transform: translateY(10rpx) scale(1.05); }
  30% { transform: translateY(0) scale(1); }
  100% { opacity: 0; transform: translateY(-100rpx) scale(0.9); }
}

.side-btns {
  position: fixed;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 100;
}

.side-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(139, 90, 43, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(60, 35, 20, 0.08);
}

.side-btn-icon {
  font-size: 40rpx;
  opacity: 0.85;
}

.bottom-btns {
  padding-bottom: 48rpx;
  z-index: 10;
}

.share-btn {
  display: flex;
  align-items: center;
  padding: 24rpx 48rpx;
  background: rgba(184, 134, 11, 0.1);
  border-radius: 48rpx;
  border: 1rpx solid rgba(184, 134, 11, 0.2);
}

.share-btn::after {
  border: none;
}

.share-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.share-text {
  font-size: 26rpx;
  color: #B8860B;
}
