/* pages/index/index.wxss - 禅意檀香主题 */

/* ========================================
   主容器 - 禅意氛围背景
   ======================================== */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  height: 100vh;
  padding: 40rpx 0;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
}

/* 背景图片层 */
.background-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 檀香烟雾氛围层 */
.container::before {
  content: '';
  position: absolute;
  top: -20%;
  left: -10%;
  right: -10%;
  bottom: -20%;
  background:
    radial-gradient(ellipse 80% 50% at 20% 30%, rgba(139, 90, 43, 0.03) 0%, transparent 50%),
    radial-gradient(ellipse 60% 40% at 80% 70%, rgba(139, 90, 43, 0.02) 0%, transparent 50%),
    radial-gradient(ellipse 100% 60% at 50% 100%, rgba(184, 134, 11, 0.02) 0%, transparent 40%);
  pointer-events: none;
  z-index: 0;
}

/* ========================================
   功德计数器 - 醒目样式
   ======================================== */
.merit-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
  position: relative;
  z-index: 10;
}

.merit-label {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 20rpx;
  color: rgba(255, 240, 220, 0.85);
  margin-bottom: 12rpx;
  text-indent: 20rpx;
  text-shadow: 0 2rpx 8rpx rgba(60, 35, 20, 0.5);
}

.merit-value {
  font-size: 60rpx;
  font-weight: 700;
  color: #FFD700;
  text-shadow:
    0 0 10rpx rgba(255, 215, 0, 0.8),
    0 0 30rpx rgba(255, 180, 0, 0.5),
    0 0 50rpx rgba(255, 140, 0, 0.3),
    0 4rpx 8rpx rgba(60, 35, 20, 0.4);
  line-height: 1.2;
  position: relative;
  -webkit-text-stroke: 1rpx rgba(180, 120, 0, 0.3);
}

/* 功德数字下方装饰线 */
.merit-value::after {
  content: '';
  position: absolute;
  bottom: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 3rpx;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 215, 0, 0.8) 20%,
    transparent 100%
  );
  box-shadow: 0 0 10rpx rgba(255, 200, 100, 0.5);
}

/* 功德数字呼吸动画 */
.merit-value.bounce {
  animation: meritPulse 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes meritPulse {
  0% { transform: scale(1); }
  40% { transform: scale(1.08); }
  100% { transform: scale(1); }
}

/* ========================================
   念珠区域 - 核心交互区
   ======================================== */
.beads-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  position: relative;
  z-index: 5;
}

.beads-container {
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
  /* 显示10颗珠子 */
  height: 970rpx;
}

/* 珠子容器光影氛围 */
.beads-container::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 300rpx;
  height: 300rpx;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle,
    rgba(184, 134, 11, 0.08) 0%,
    transparent 70%
  );
  pointer-events: none;
  z-index: -1;
}

.beads-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: none;
  margin-top: -100rpx;
  will-change: transform;
  transform: translateZ(0);
}

.beads-wrapper.with-transition {
  transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* 珠子包裹层 - 为放大和光晕预留空间 */
.bead-wrapper {
  width: 120rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: -6rpx 0;
  position: relative;
  overflow: visible; /* 允许放大的珠子溢出 */
}

/* ========================================
   单颗珠子 - CSS绘制（支持多材质）
   ======================================== */
.bead {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  position: relative;
  /* 默认檀木色 */
  --bead-primary: #8B5A2B;
  --bead-secondary: #A0522D;
  --bead-highlight: #D2B48C;
  --bead-shadow: #5D3A1A;
  background: radial-gradient(circle at 30% 30%,
    var(--bead-highlight) 0%,
    var(--bead-secondary) 30%,
    var(--bead-primary) 70%,
    var(--bead-shadow) 100%
  );
  box-shadow:
    inset 0 -4rpx 8rpx rgba(0, 0, 0, 0.3),
    inset 0 4rpx 12rpx rgba(255, 255, 255, 0.15),
    0 4rpx 12rpx rgba(0, 0, 0, 0.25),
    0 2rpx 4rpx rgba(0, 0, 0, 0.15);
  will-change: transform, filter;
  backface-visibility: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

/* 珠子内部纹理 */
.bead-inner {
  position: absolute;
  top: 15%;
  left: 15%;
  width: 70%;
  height: 70%;
  border-radius: 50%;
  background: radial-gradient(circle at 40% 40%,
    transparent 0%,
    rgba(0, 0, 0, 0.05) 50%,
    rgba(0, 0, 0, 0.1) 100%
  );
  opacity: 0.6;
}

/* 珠子高光 */
.bead-shine {
  position: absolute;
  top: 12%;
  left: 18%;
  width: 35%;
  height: 25%;
  border-radius: 50%;
  background: linear-gradient(180deg,
    rgba(255, 255, 255, 0.5) 0%,
    rgba(255, 255, 255, 0.1) 60%,
    transparent 100%
  );
  transform: rotate(-30deg);
}

/* ========================================
   不同材质珠子样式
   ======================================== */

/* 檀木 */
.bead-sandalwood {
  --bead-primary: #8B5A2B;
  --bead-secondary: #A0522D;
  --bead-highlight: #D2B48C;
  --bead-shadow: #5D3A1A;
}

/* 菩提 */
.bead-bodhi {
  --bead-primary: #C4A35A;
  --bead-secondary: #D4B896;
  --bead-highlight: #F5E6C8;
  --bead-shadow: #8B7355;
}

/* 水晶 */
.bead-crystal {
  --bead-primary: #B8D4E3;
  --bead-secondary: #E8F4F8;
  --bead-highlight: #FFFFFF;
  --bead-shadow: #7FB3D3;
  box-shadow:
    inset 0 -2rpx 6rpx rgba(127, 179, 211, 0.4),
    inset 0 4rpx 16rpx rgba(255, 255, 255, 0.6),
    0 4rpx 16rpx rgba(127, 179, 211, 0.3),
    0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.bead-crystal .bead-shine {
  background: linear-gradient(180deg,
    rgba(255, 255, 255, 0.8) 0%,
    rgba(255, 255, 255, 0.3) 60%,
    transparent 100%
  );
}

/* 玛瑙 */
.bead-agate {
  --bead-primary: #8B3A3A;
  --bead-secondary: #B85050;
  --bead-highlight: #D4A5A5;
  --bead-shadow: #5C2828;
}

/* 翡翠 */
.bead-jade {
  --bead-primary: #5B8A5B;
  --bead-secondary: #7CB97C;
  --bead-highlight: #A8D8A8;
  --bead-shadow: #3D5C3D;
  box-shadow:
    inset 0 -3rpx 8rpx rgba(61, 92, 61, 0.4),
    inset 0 4rpx 14rpx rgba(255, 255, 255, 0.25),
    0 4rpx 14rpx rgba(61, 92, 61, 0.3),
    0 2rpx 6rpx rgba(0, 0, 0, 0.2);
}

/* ========================================
   激活状态 - 放大 + 光晕
   ======================================== */
.bead.active {
  transform: scale(1.15) translateZ(0);
  filter: drop-shadow(0 0 10rpx rgba(218, 165, 32, 0.3))
    drop-shadow(0 6rpx 12rpx rgba(30, 15, 5, 0.15));
}

/* 激活光晕动画 - 更柔和 */
.bead-highlight {
  position: absolute;
  top: -15rpx;
  left: -15rpx;
  right: -15rpx;
  bottom: -15rpx;
  border-radius: 50%;
  border: 1.5rpx solid rgba(218, 165, 32, 0.4);
  animation: breathe 2s ease-in-out infinite;
}

@keyframes breathe {
  0%, 100% {
    transform: scale(1);
    opacity: 0.6;
    border-color: rgba(218, 165, 32, 0.35);
  }
  50% {
    transform: scale(1.1);
    opacity: 0.25;
    border-color: rgba(184, 134, 11, 0.2);
  }
}

/* ========================================
   底部按钮区域 - 醒目样式
   ======================================== */
.bottom-btns {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: 24rpx;
  position: relative;
  z-index: 10;
}

/* 分享按钮 */
.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 56rpx;
  background: linear-gradient(135deg,
    rgba(90, 55, 30, 0.85) 0%,
    rgba(70, 45, 25, 0.9) 100%
  );
  border-radius: 48rpx;
  border: 2rpx solid rgba(140, 90, 50, 0.5);
  position: relative;
  overflow: hidden;
  box-shadow:
    0 4rpx 20rpx rgba(60, 35, 20, 0.3),
    0 2rpx 8rpx rgba(40, 25, 15, 0.2);
}

.share-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 48rpx;
  background: linear-gradient(180deg,
    rgba(255, 255, 255, 0.25) 0%,
    transparent 50%
  );
  pointer-events: none;
}

.share-btn::after {
  border: none;
}

.share-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.share-text {
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 6rpx;
  color: #FFF5E6;
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.3);
}

/* 设置按钮 */
.settings-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========================================
   右侧按钮区域 - 右上角竖向排列
   ======================================== */
.side-btns {
  position: fixed;
  right: 32rpx;
  top: 30%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  z-index: 100;
}

.side-btn-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.side-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.95) 0%,
    rgba(250, 245, 240, 0.9) 100%
  );
  border: 1rpx solid rgba(139, 90, 43, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 4rpx 16rpx rgba(60, 35, 20, 0.08),
    0 2rpx 8rpx rgba(60, 35, 20, 0.04);
  position: relative;
  overflow: hidden;
}

.side-btn-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFF5E6;
  letter-spacing: 2rpx;
  text-shadow: 0 1rpx 4rpx rgba(60, 35, 20, 0.5);
}

.side-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background: linear-gradient(180deg,
    rgba(255, 255, 255, 0.5) 0%,
    transparent 50%
  );
  pointer-events: none;
}

.side-btn:active {
  transform: scale(0.95);
  box-shadow:
    0 2rpx 8rpx rgba(60, 35, 20, 0.1),
    0 1rpx 4rpx rgba(60, 35, 20, 0.05);
}

.side-btn-icon {
  font-size: 40rpx;
  opacity: 0.85;
}

/* 换肤按钮特殊样式 */
.side-btn.skin-btn {
  background: linear-gradient(135deg,
    rgba(184, 134, 11, 0.1) 0%,
    rgba(255, 255, 255, 0.95) 100%
  );
}

/* 设置按钮特殊样式 */
.side-btn.settings-btn {
  background: linear-gradient(135deg,
    rgba(92, 58, 33, 0.08) 0%,
    rgba(255, 255, 255, 0.95) 100%
  );
}

/* 重置按钮特殊样式 */
.side-btn.reset-btn {
  background: linear-gradient(135deg,
    rgba(180, 80, 80, 0.15) 0%,
    rgba(255, 255, 255, 0.95) 100%
  );
}

/* ========================================
   功德+1 飘字 - 醒目效果
   ======================================== */
.merit-popup {
  position: absolute;
  left: 30%;
  top: 50%;
  margin-top: -200rpx;
  margin-left: -55rpx;
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: #FFD700;
  text-shadow:
    0 0 8rpx rgba(255, 215, 0, 0.9),
    0 0 20rpx rgba(255, 180, 0, 0.6),
    0 0 40rpx rgba(255, 140, 0, 0.4),
    0 2rpx 4rpx rgba(60, 35, 20, 0.5);
  -webkit-text-stroke: 1rpx rgba(180, 100, 0, 0.3);
  white-space: nowrap;
  pointer-events: none;
  z-index: 9999;
  animation: meritRise 1.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

@keyframes meritRise {
  0% {
    opacity: 0;
    transform: translateY(-30rpx) scale(0.7);
  }
  15% {
    opacity: 1;
    transform: translateY(-100rpx) scale(1.05);
  }
  30% {
    transform: translateY(-140rpx) scale(1);
  }
  70% {
    opacity: 0.9;
    transform: translateY(-240rpx) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(-300rpx) scale(0.9);
  }
}

/* ========================================
   檀香烟雾粒子 - 禅意氛围
   ======================================== */
.incense-particles {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}

.particle {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  background: radial-gradient(circle,
    rgba(184, 134, 11, 0.15) 0%,
    rgba(184, 134, 11, 0.05) 50%,
    transparent 100%
  );
  border-radius: 50%;
  animation: floatUp 8s ease-in-out infinite;
}

.particle-1 {
  left: 15%;
  bottom: 20%;
  animation-delay: 0s;
  animation-duration: 10s;
}

.particle-2 {
  left: 30%;
  bottom: 15%;
  animation-delay: 1.5s;
  animation-duration: 12s;
  width: 4rpx;
  height: 4rpx;
}

.particle-3 {
  left: 50%;
  bottom: 25%;
  animation-delay: 3s;
  animation-duration: 9s;
}

.particle-4 {
  left: 70%;
  bottom: 18%;
  animation-delay: 4.5s;
  animation-duration: 11s;
  width: 5rpx;
  height: 5rpx;
}

.particle-5 {
  left: 85%;
  bottom: 22%;
  animation-delay: 6s;
  animation-duration: 13s;
  width: 4rpx;
  height: 4rpx;
}

@keyframes floatUp {
  0% {
    transform: translateY(0) translateX(0) scale(0.5);
    opacity: 0;
  }
  10% {
    opacity: 0.6;
  }
  50% {
    transform: translateY(-300rpx) translateX(20rpx) scale(1);
    opacity: 0.4;
  }
  90% {
    opacity: 0.1;
  }
  100% {
    transform: translateY(-600rpx) translateX(-10rpx) scale(0.3);
    opacity: 0;
  }
}

/* ========================================
   换肤弹窗
   ======================================== */
.skin-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.skin-picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.skin-picker {
  width: 100%;
  background: linear-gradient(180deg,
    #FDF8F3 0%,
    #F5EDE3 100%
  );
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.skin-picker-mask.show .skin-picker {
  transform: translateY(0);
}

.skin-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(139, 90, 43, 0.1);
}

.skin-picker-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--primary-dark, #3D2314);
  letter-spacing: 2rpx;
}

.skin-picker-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--text-muted, #8B7355);
  line-height: 1;
}

.skin-picker-content {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  justify-content: flex-start;
}

.skin-option {
  width: calc(33.33% - 16rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  position: relative;
  transition: all 0.25s ease;
}

.skin-option.selected {
  border-color: var(--accent-gold, #B8860B);
  background: rgba(184, 134, 11, 0.08);
}

.skin-preview {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.skin-preview-bead {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  position: relative;
}

/* 弹窗内的珠子预览样式 */
.skin-preview-bead {
  box-shadow:
    inset 0 -3rpx 6rpx rgba(0, 0, 0, 0.25),
    inset 0 3rpx 10rpx rgba(255, 255, 255, 0.15),
    0 3rpx 10rpx rgba(0, 0, 0, 0.2);
}

/* 檀木预览 */
.skin-option .bead-sandalwood {
  background: radial-gradient(circle at 30% 30%,
    #D2B48C 0%, #A0522D 30%, #8B5A2B 70%, #5D3A1A 100%
  );
}

/* 菩提预览 */
.skin-option .bead-bodhi {
  background: radial-gradient(circle at 30% 30%,
    #F5E6C8 0%, #D4B896 30%, #C4A35A 70%, #8B7355 100%
  );
}

/* 水晶预览 */
.skin-option .bead-crystal {
  background: radial-gradient(circle at 30% 30%,
    #FFFFFF 0%, #E8F4F8 30%, #B8D4E3 70%, #7FB3D3 100%
  );
  box-shadow:
    inset 0 -2rpx 5rpx rgba(127, 179, 211, 0.4),
    inset 0 3rpx 12rpx rgba(255, 255, 255, 0.6),
    0 3rpx 12rpx rgba(127, 179, 211, 0.3);
}

/* 玛瑙预览 */
.skin-option .bead-agate {
  background: radial-gradient(circle at 30% 30%,
    #D4A5A5 0%, #B85050 30%, #8B3A3A 70%, #5C2828 100%
  );
}

/* 翡翠预览 */
.skin-option .bead-jade {
  background: radial-gradient(circle at 30% 30%,
    #A8D8A8 0%, #7CB97C 30%, #5B8A5B 70%, #3D5C3D 100%
  );
  box-shadow:
    inset 0 -2rpx 6rpx rgba(61, 92, 61, 0.4),
    inset 0 3rpx 12rpx rgba(255, 255, 255, 0.25),
    0 3rpx 12rpx rgba(61, 92, 61, 0.3);
}

.skin-option .bead-inner,
.skin-option .bead-shine {
  transform: scale(0.7);
}

.skin-name {
  font-size: 24rpx;
  color: var(--text-secondary, #5C3A21);
  letter-spacing: 2rpx;
}

.skin-check {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  background: var(--accent-gold, #B8860B);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #FFFFFF;
}
