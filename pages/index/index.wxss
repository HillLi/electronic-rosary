/* pages/index/index.wxss - 禅意檀香主题 */

/* ========================================
   主容器 - 禅意氛围背景
   ======================================== */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  height: 100vh;
  padding: 40rpx 0;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
}

/* 檀香烟雾氛围层 */
.container::before {
  content: '';
  position: absolute;
  top: -20%;
  left: -10%;
  right: -10%;
  bottom: -20%;
  background:
    radial-gradient(ellipse 80% 50% at 20% 30%, rgba(139, 90, 43, 0.03) 0%, transparent 50%),
    radial-gradient(ellipse 60% 40% at 80% 70%, rgba(139, 90, 43, 0.02) 0%, transparent 50%),
    radial-gradient(ellipse 100% 60% at 50% 100%, rgba(184, 134, 11, 0.02) 0%, transparent 40%);
  pointer-events: none;
  z-index: 0;
}

/* ========================================
   功德计数器 - 优雅排版
   ======================================== */
.merit-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  position: relative;
  z-index: 10;
}

.merit-label {
  font-size: 28rpx;
  letter-spacing: 16rpx;
  color: var(--text-muted, #8B7355);
  margin-bottom: 8rpx;
  text-indent: 16rpx;
}

.merit-value {
  font-size: 96rpx;
  font-weight: 300;
  color: var(--primary-dark, #3D2314);
  text-shadow:
    0 2rpx 4rpx rgba(60, 35, 20, 0.1),
    0 4rpx 12rpx rgba(60, 35, 20, 0.05);
  line-height: 1.2;
  position: relative;
}

/* 功德数字下方装饰线 */
.merit-value::after {
  content: '';
  position: absolute;
  bottom: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg,
    transparent 0%,
    var(--accent-gold, #B8860B) 50%,
    transparent 100%
  );
  opacity: 0.4;
}

/* 功德数字呼吸动画 */
.merit-value.bounce {
  animation: meritPulse 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes meritPulse {
  0% { transform: scale(1); }
  40% { transform: scale(1.08); }
  100% { transform: scale(1); }
}

/* ========================================
   念珠区域 - 核心交互区
   ======================================== */
.beads-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  position: relative;
  z-index: 5;
}

.beads-container {
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

/* 珠子容器光影氛围 */
.beads-container::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 300rpx;
  height: 300rpx;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle,
    rgba(184, 134, 11, 0.08) 0%,
    transparent 70%
  );
  pointer-events: none;
  z-index: -1;
}

.beads-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: none;
}

.beads-wrapper.with-transition {
  transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* 珠子包裹层 - 为放大和光晕预留空间 */
.bead-wrapper {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 8rpx 0;
  position: relative;
}

/* ========================================
   单颗珠子 - 精致檀木质感
   ======================================== */
.bead {
  width: 100rpx;
  height: 100rpx;
  position: relative;
  border-radius: 50%;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);

  /* 多层檀木质感 - 纵向木纹 */
  background:
    /* 顶部高光 - 柔和漫反射 */
    radial-gradient(ellipse 50% 35% at 30% 22%,
      rgba(255, 250, 240, 0.2) 0%,
      rgba(255, 250, 240, 0.08) 40%,
      transparent 70%
    ),
    /* 纵向主木纹 */
    repeating-linear-gradient(
      88deg,
      transparent 0rpx,
      rgba(35, 18, 8, 0.35) 1.5rpx,
      rgba(50, 28, 14, 0.25) 3rpx,
      transparent 5rpx,
      rgba(40, 22, 10, 0.3) 7rpx,
      transparent 9rpx,
      rgba(45, 25, 12, 0.2) 12rpx,
      transparent 15rpx
    ),
    /* 纵向次木纹 - 错位 */
    repeating-linear-gradient(
      92deg,
      transparent 2rpx,
      rgba(30, 15, 5, 0.2) 4rpx,
      transparent 6rpx,
      rgba(55, 30, 15, 0.15) 10rpx,
      transparent 14rpx
    ),
    /* 基础檀木色渐变 */
    radial-gradient(circle at 38% 35%,
      #5D3D25 0%,
      #4A2C17 35%,
      #3A2010 65%,
      #2A150A 100%
    );

  /* 立体阴影 */
  box-shadow:
    /* 环境光遮挡 */
    0 8rpx 20rpx rgba(30, 15, 5, 0.25),
    0 2rpx 6rpx rgba(30, 15, 5, 0.15),
    /* 内部立体感 */
    inset 4rpx 4rpx 10rpx rgba(0, 0, 0, 0.25),
    inset -3rpx -3rpx 8rpx rgba(255, 250, 240, 0.08),
    /* 边缘高光 */
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 细腻木纹层 */
.bead::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background:
    repeating-linear-gradient(
      86deg,
      transparent 0rpx,
      rgba(25, 12, 5, 0.12) 0.8rpx,
      transparent 1.6rpx,
      rgba(40, 22, 10, 0.1) 2.4rpx,
      transparent 3.2rpx
    );
  pointer-events: none;
}

/* 珠子内部高光 - 哑光效果 */
.bead-inner {
  position: absolute;
  top: 12%;
  left: 18%;
  width: 35%;
  height: 25%;
  background:
    radial-gradient(ellipse at 45% 40%,
      rgba(255, 252, 245, 0.3) 0%,
      rgba(255, 252, 245, 0.1) 50%,
      transparent 80%
    );
  border-radius: 50%;
  transform: rotate(-30deg);
  pointer-events: none;
}

/* ========================================
   激活状态 - 温润光晕
   ======================================== */
.bead.active {
  transform: scale(1.18);

  /* 更亮的檀木色 */
  background:
    /* 强化高光 */
    radial-gradient(ellipse 55% 40% at 30% 22%,
      rgba(255, 252, 240, 0.3) 0%,
      rgba(255, 252, 240, 0.12) 40%,
      transparent 70%
    ),
    /* 木纹 - 略亮 */
    repeating-linear-gradient(
      88deg,
      transparent 0rpx,
      rgba(50, 28, 14, 0.35) 1.5rpx,
      rgba(70, 42, 22, 0.28) 3rpx,
      transparent 5rpx,
      rgba(60, 35, 18, 0.3) 7rpx,
      transparent 9rpx,
      rgba(55, 32, 16, 0.22) 12rpx,
      transparent 15rpx
    ),
    repeating-linear-gradient(
      92deg,
      transparent 2rpx,
      rgba(45, 25, 12, 0.22) 4rpx,
      transparent 6rpx,
      rgba(65, 38, 20, 0.18) 10rpx,
      transparent 14rpx
    ),
    /* 更亮的基色 */
    radial-gradient(circle at 38% 35%,
      #6D4D35 0%,
      #5A3A28 35%,
      #4A2A18 65%,
      #3A1A0E 100%
    );

  box-shadow:
    /* 暖色光晕 */
    0 0 30rpx rgba(218, 165, 32, 0.25),
    0 0 60rpx rgba(184, 134, 11, 0.12),
    /* 立体阴影 */
    0 10rpx 25rpx rgba(30, 15, 5, 0.2),
    inset 4rpx 4rpx 10rpx rgba(0, 0, 0, 0.2),
    inset -3rpx -3rpx 8rpx rgba(255, 250, 240, 0.1);
}

/* 激活光晕动画 - 更柔和 */
.bead-highlight {
  position: absolute;
  top: -15rpx;
  left: -15rpx;
  right: -15rpx;
  bottom: -15rpx;
  border-radius: 50%;
  border: 1.5rpx solid rgba(218, 165, 32, 0.4);
  animation: breathe 2s ease-in-out infinite;
}

@keyframes breathe {
  0%, 100% {
    transform: scale(1);
    opacity: 0.6;
    border-color: rgba(218, 165, 32, 0.35);
  }
  50% {
    transform: scale(1.1);
    opacity: 0.25;
    border-color: rgba(184, 134, 11, 0.2);
  }
}

/* ========================================
   设置按钮 - 禅意风格
   ======================================== */
.settings-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  background: linear-gradient(135deg,
    rgba(92, 58, 33, 0.06) 0%,
    rgba(92, 58, 33, 0.02) 100%
  );
  border-radius: 48rpx;
  margin-bottom: 48rpx;
  position: relative;
  z-index: 10;
  border: 1rpx solid rgba(92, 58, 33, 0.08);
}

.settings-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 48rpx;
  background: linear-gradient(180deg,
    rgba(255, 255, 255, 0.15) 0%,
    transparent 50%
  );
  pointer-events: none;
}

.settings-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  opacity: 0.8;
}

.settings-text {
  font-size: 26rpx;
  letter-spacing: 4rpx;
  color: var(--text-secondary, #5C3A21);
  text-indent: 4rpx;
}

/* ========================================
   功德+1 飘字 - 优雅升起
   ======================================== */
.merit-popup {
  position: absolute;
  left: 50%;
  top: 50%;
  margin-top: -20rpx;
  margin-left: -55rpx;
  font-size: 32rpx;
  font-weight: 400;
  letter-spacing: 2rpx;
  color: var(--accent-gold, #B8860B);
  text-shadow:
    0 0 12rpx rgba(218, 165, 32, 0.5),
    0 2rpx 4rpx rgba(30, 15, 5, 0.1);
  white-space: nowrap;
  pointer-events: none;
  z-index: 9999;
  animation: meritRise 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

@keyframes meritRise {
  0% {
    opacity: 0;
    transform: translateY(40rpx) scale(0.7);
  }
  15% {
    opacity: 1;
    transform: translateY(10rpx) scale(1.05);
  }
  30% {
    transform: translateY(0) scale(1);
  }
  70% {
    opacity: 0.9;
    transform: translateY(-60rpx) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(-100rpx) scale(0.9);
  }
}

/* ========================================
   檀香烟雾粒子 - 禅意氛围
   ======================================== */
.incense-particles {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}

.particle {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  background: radial-gradient(circle,
    rgba(184, 134, 11, 0.15) 0%,
    rgba(184, 134, 11, 0.05) 50%,
    transparent 100%
  );
  border-radius: 50%;
  animation: floatUp 8s ease-in-out infinite;
}

.particle-1 {
  left: 15%;
  bottom: 20%;
  animation-delay: 0s;
  animation-duration: 10s;
}

.particle-2 {
  left: 30%;
  bottom: 15%;
  animation-delay: 1.5s;
  animation-duration: 12s;
  width: 4rpx;
  height: 4rpx;
}

.particle-3 {
  left: 50%;
  bottom: 25%;
  animation-delay: 3s;
  animation-duration: 9s;
}

.particle-4 {
  left: 70%;
  bottom: 18%;
  animation-delay: 4.5s;
  animation-duration: 11s;
  width: 5rpx;
  height: 5rpx;
}

.particle-5 {
  left: 85%;
  bottom: 22%;
  animation-delay: 6s;
  animation-duration: 13s;
  width: 4rpx;
  height: 4rpx;
}

@keyframes floatUp {
  0% {
    transform: translateY(0) translateX(0) scale(0.5);
    opacity: 0;
  }
  10% {
    opacity: 0.6;
  }
  50% {
    transform: translateY(-300rpx) translateX(20rpx) scale(1);
    opacity: 0.4;
  }
  90% {
    opacity: 0.1;
  }
  100% {
    transform: translateY(-600rpx) translateX(-10rpx) scale(0.3);
    opacity: 0;
  }
}
