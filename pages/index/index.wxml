<!--pages/index/index.wxml - 禅意檀香主题-->
<view
  class="container"
  bindtouchstart="onTouchStart"
  bindtouchmove="onTouchMove"
  bindtouchend="onTouchEnd"
>
  <!-- 檀香烟雾粒子层 -->
  <view class="incense-particles">
    <view class="particle particle-1"></view>
    <view class="particle particle-2"></view>
    <view class="particle particle-3"></view>
    <view class="particle particle-4"></view>
    <view class="particle particle-5"></view>
  </view>

  <!-- 功德计数器 -->
  <view class="merit-container">
    <view class="merit-label">功德</view>
    <view class="merit-value {{meritAnimating ? 'bounce' : ''}}">{{merit}}</view>
  </view>

  <!-- 念珠区域（包含珠子和飘字） -->
  <view class="beads-area">
    <view class="beads-container">
      <view
        class="beads-wrapper {{useTransition ? 'with-transition' : ''}}"
        style="transform: translateY({{translateY}}px);"
      >
        <view
          wx:for="{{visibleBeads}}"
          wx:for-index="idx"
          wx:key="id"
          class="bead-wrapper"
        >
          <!-- CSS绘制的珠子 -->
          <view
            class="bead {{item.isActive ? 'active' : ''}} bead-{{currentSkin.id}}"
            style="{{item.isActive ? '--bead-primary: ' + currentSkin.colors.primary + '; --bead-secondary: ' + currentSkin.colors.secondary + '; --bead-highlight: ' + currentSkin.colors.highlight + '; --bead-shadow: ' + currentSkin.colors.shadow : ''}}"
          >
            <view class="bead-inner"></view>
            <view class="bead-shine"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 功德+1 飘字动画 -->
    <view
      wx:for="{{meritPopups}}"
      wx:key="id"
      class="merit-popup"
    >
      功德+{{item.count}}
    </view>
  </view>

  <!-- 底部按钮区域 -->
  <view class="bottom-btns">
    <button class="share-btn" open-type="share">
      <text class="share-icon">🙏</text>
      <text class="share-text">邀请好友</text>
    </button>
    <view class="skin-btn" catchtap="openSkinPicker">
      <text class="skin-icon">🎨</text>
      <text class="skin-text">换肤</text>
    </view>
    <view class="settings-btn" catchtap="goToSettings">
      <text class="settings-icon">☸</text>
      <text class="settings-text">设置</text>
    </view>
  </view>
</view>

<!-- 换肤弹窗 -->
<view class="skin-picker-mask {{showSkinPicker ? 'show' : ''}}" catchtap="closeSkinPicker">
  <view class="skin-picker" catchtap="">
    <view class="skin-picker-header">
      <text class="skin-picker-title">选择念珠材质</text>
      <view class="skin-picker-close" catchtap="closeSkinPicker">×</view>
    </view>
    <view class="skin-picker-content">
      <view
        wx:for="{{beadSkins}}"
        wx:key="id"
        class="skin-option {{currentSkin.id === item.id ? 'selected' : ''}}"
        data-skin-id="{{item.id}}"
        bindtap="selectSkin"
      >
        <view class="skin-preview bead-{{item.id}}">
          <view class="skin-preview-bead">
            <view class="bead-inner"></view>
            <view class="bead-shine"></view>
          </view>
        </view>
        <text class="skin-name">{{item.name}}</text>
        <view class="skin-check" wx:if="{{currentSkin.id === item.id}}">✓</view>
      </view>
    </view>
  </view>
</view>
