/* pages/settings/settings.wxss */

.settings-container {
  padding: 30rpx;
  background-color: #F5E6D3;
  min-height: 100vh;
}

.settings-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #5D4037;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.option-group {
  display: flex;
  flex-direction: column;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
}

.option-content {
  flex: 1;
}

.option-label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.option-desc {
  font-size: 24rpx;
  color: #999;
}

/* 使用说明样式 */
.tips {
  padding: 10rpx 0;
}

.tip-item {
  font-size: 28rpx;
  color: #666;
  line-height: 2;
}
