  },
  "homepage": "https://github.com/HillLi/electronic-rosary#readme",
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "miniprogram-automator": "^0.12.1",
    "prettier": "^3.2.5"
  }
}
