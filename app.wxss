/* app.wxss - 禅意檀香主题 */

/* 引入更有个性的中文字体 */
page {
  background: linear-gradient(165deg, #F8F0E3 0%, #EDE4D3 50%, #E5D9C6 100%);
  font-family:
    "Noto Serif SC",
    "Source Han Serif CN",
    "LXGW WenKai",
    "FangSong",
    "STFangsong",
    -apple-system,
    BlinkMacSystemFont,
    sans-serif;
  height: 100%;
  position: relative;
  overflow: hidden;
}

/* 禅意主题色系 - 更有层次感的配色 */
:root {
  /* 主色调 - 深檀木棕 */
  --primary-dark: #3D2314;
  --primary: #5C3A21;
  --primary-light: #8B5A2B;

  /* 珠子色 */
  --bead-base: #4A2C17;
  --bead-light: #6B4423;
  --bead-highlight: #8B6914;

  /* 背景 */
  --bg-cream: #F8F0E3;
  --bg-warm: #EDE4D3;
  --bg-soft: #E5D9C6;

  /* 点缀色 - 暖金 */
  --accent-gold: #B8860B;
  --accent-glow: #DAA520;
  --accent-light: #F5DEB3;

  /* 文字 */
  --text-primary: #2C1810;
  --text-secondary: #5C3A21;
  --text-muted: #8B7355;

  /* 阴影 */
  --shadow-soft: rgba(60, 35, 20, 0.08);
  --shadow-medium: rgba(60, 35, 20, 0.15);
  --shadow-deep: rgba(30, 15, 5, 0.25);
}

/* 全局页面背景纹理 - 宣纸质感 */
page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image:
    url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  opacity: 0.03;
  pointer-events: none;
  z-index: 0;
}
