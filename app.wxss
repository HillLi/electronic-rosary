/* app.wxss - 全局样式 */
page {
  background-color: #F5E6D3;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  height: 100%;
}

/* 念珠主题色 */
:root {
  --primary-color: #8B4513;
  --bead-color: #D2691E;
  --bead-highlight: #FFD700;
  --bg-color: #F5E6D3;
  --text-color: #5D4037;
}
